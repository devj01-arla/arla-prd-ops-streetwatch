# StreetWatch Frontend - Vercel

# Backend Node.js desplegado en Render
VITE_API_URL=https://arla-prd-ops-streetwatch-backend.onrender.com/api

# Socket/WebSocket del backend en Render
VITE_SOCKET_URL=https://arla-prd-ops-streetwatch-backend.onrender.com

# FastAPI / Motor IA
# En Vercel no uses localhost. Si FastAPI no tiene URL publica,
# deja esta variable sin configurar y se mostrara "NO SIGNAL".
VITE_FASTAPI_URL=
